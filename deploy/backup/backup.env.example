# /etc/llavero/backup.env — environment for llavero-backup.service
# Copy this to /etc/llavero/backup.env and fill in real values.
# chmod 640, owned root:llavero

# Database
LLAVERO_DB_NAME=llavero
LLAVERO_DB_USER=llavero

# Public key recipients file (age format, one "age1..." key per line).
# The private key is NEVER present on this machine — only the public key.
LLAVERO_BACKUP_PUBKEY=/etc/llavero/backup.pub

# Local staging and archive root
LLAVERO_BACKUP_DIR=/var/backups/llavero

# Three backup destinations (rsync user@host:path — Annex H 4)
# Copy 1: separate internal host (also holds audit anchors)
LLAVERO_BACKUP_HOST1=backup@separate-host.internal:/srv/llavero-backups
# Copy 2: NAS or second host
LLAVERO_BACKUP_HOST2=backup@nas.internal:/llavero-backups
# Copy 3: offsite office over MikroTik site-to-site tunnel
LLAVERO_BACKUP_HOST3=backup@offsite.internal:/srv/llavero-backups

# Status / monitoring
LLAVERO_STATUS_PATH=/var/log/llavero/backup-status.json

# Django project paths
LLAVERO_DJANGO_DIR=/opt/llavero
LLAVERO_VENV=/opt/llavero/.venv

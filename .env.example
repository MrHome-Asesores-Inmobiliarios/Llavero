# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# NOTE: python-decouple does not strip inline comments.
#       Keep comments on their own lines, not after values.

# Django
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DJANGO_SETTINGS_MODULE=llavero.settings.dev

# Database (PostgreSQL, scram-sha-256 auth set in pg_hba.conf)
DB_NAME=llavero
DB_USER=llavero
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
# use "require" in production behind internal CA
DB_SSLMODE=prefer

# Production only
# ALLOWED_HOSTS=llavero.internal
# LOG_FILE=/var/log/llavero/app.log

# Security timeouts (seconds)
# 15 min idle auto-lock
IDLE_LOCK_SECONDS=900
# 2 min step-up reauth window
STEPUP_WINDOW_SECONDS=120

# Vault second factor (Annex A 5.2, Annex G 4)
# "tpm" on the hardened server; "keyfile" fallback for dev/test
SECOND_FACTOR_MODE=keyfile
# KEYFILE_PATH must be OFF the backup path, owner-only perms (0600).
# Dev/test: any writable path works, e.g. C:\Apps\Llavero\vault.keyfile
KEYFILE_PATH=

# Session handover timers (Annex D 8)
HANDOVER_IDLE_YIELD_SECONDS=120
HANDOVER_GRACE_SECONDS=300
HANDOVER_EXTEND_SECONDS=600
HANDOVER_RELEASE_LOCK_SECONDS=5

# Backup (Phase 2, Annex H)
BACKUP_STATUS_PATH=
BACKUP_ARCHIVE_DIR=
BACKUP_OVERDUE_HOURS=26

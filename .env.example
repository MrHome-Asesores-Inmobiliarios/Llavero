# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# Django
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DJANGO_SETTINGS_MODULE=llavero.settings.dev

# Database (PostgreSQL, scram-sha-256 auth set in pg_hba.conf)
DB_NAME=llavero
DB_USER=llavero
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer          # use "require" in production behind internal CA

# Production only
# ALLOWED_HOSTS=llavero.internal
# LOG_FILE=/var/log/llavero/app.log

# Security timeouts (seconds)
IDLE_LOCK_SECONDS=900      # 15 min idle auto-lock
STEPUP_WINDOW_SECONDS=120  # 2 min step-up reauth window

# Vault second factor (Annex A 5.2, Annex G 4)
SECOND_FACTOR_MODE=keyfile        # "tpm" on the hardened server; "keyfile" fallback
# KEYFILE_PATH must be OFF the backup path, owner-only perms (0600).
# Example (server): /etc/llavero/vault.keyfile
KEYFILE_PATH=

# Session handover timers (Annex D 8)
HANDOVER_IDLE_YIELD_SECONDS=120
HANDOVER_GRACE_SECONDS=300
HANDOVER_EXTEND_SECONDS=600
HANDOVER_RELEASE_LOCK_SECONDS=5

# Backup (Phase 2, Annex H)
# Path where backup.sh writes its JSON result after each run.
BACKUP_STATUS_PATH=/var/log/llavero/backup-status.json
# Local archive directory for encrypted backup files.
BACKUP_ARCHIVE_DIR=/var/backups/llavero/archive
# Alert if no successful backup within this many hours (24 h + 2 h grace).
BACKUP_OVERDUE_HOURS=26
